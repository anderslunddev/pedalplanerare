# Copy to ".env" and adjust (Compose reads .env automatically from this directory).
# Never commit real secrets.

# Required length ≥ 32 characters (see JwtUtil).
JWT_SECRET=local-docker-dev-only-secret-min-32-chars-ok

# Browser origins allowed to call the API with credentials (comma-separated).
# Include Vite dev URL if you use frontend on :5173 against this backend.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# Optional: avoid clashing with a Postgres already on your machine.
# POSTGRES_PUBLISH_PORT=5433

# Optional: map app/debug to different host ports.
# APP_PUBLISH_PORT=8081
# DEBUG_PUBLISH_PORT=5006

# Loosen login rate limit for local testing (optional).
# RATE_LIMIT_AUTH_MAX_PER_WINDOW=10000
